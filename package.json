        "@types/express-ws": "^3.0.5",
        "@types/jsonwebtoken": "^9.0.0",
        "@types/morgan": "^1.9.9",
        "@types/multer": "^1.4.12",
        "@types/node": "^24.12.2",
        "@types/uuid": "^10.0.0",
        "@types/ws": "^8.5.10",
