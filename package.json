    "scripts": {
        "start": "node ./dist/run.js",
        "restart": "pm2 restart spire && pm2 logs spire",
        "build": "tsc",
        "prettier": "prettier '**/*.{ts,tsx,json,md}' --tab-width 4 --trailing-comma es5 --ignore-path .gitignore --arrow-parens always --write",
